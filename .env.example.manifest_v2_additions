# === Manifest v2 architecture flags ===
APP_VERSION=0.3.0-manifest-v2
LLM_PROVIDER_NAME=openai-compatible

# Vision fallback switch. Leave false if current model cannot read images.
VISION_ENABLED=true

# Memory v2: salience-aware facts and snapshots.
MEMORY_FACTS_ENABLED=true

# Self-state and relationship state. Keep enabled after migration 0002.
SELF_STATE_ENABLED=true
RELATIONSHIP_STATE_ENABLED=true

# Continuous personality modulation instead of hard mode switching.
MODE_ROUTER_ENABLED=true
PROMPT_BUILDER_V2_ENABLED=true
PROMPT_TOKEN_BUDGET=12000

# LLM request table: kind, latency, status, future cost/tokens.
LLM_LOGGING_ENABLED=true

# Future proactivity v2 switch. Kept disabled until trigger scoring is implemented.
MOTIVATED_PROACTIVE_ENABLED=false
