# === Telegram ===
TELEGRAM_BOT_TOKEN=put_telegram_bot_token_here

# === LLM: OpenAI-compatible endpoint ===
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=put_llm_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER_NAME=openai-compatible
LLM_TIMEOUT_SECONDS=60

# Сэмплинг LLM.
LLM_TEMPERATURE=0.85
LLM_TOP_P=
LLM_PRESENCE_PENALTY=0.4
LLM_FREQUENCY_PENALTY=0.5
LLM_MAX_TOKENS=

# === Postgres ===
POSTGRES_DB=iya
POSTGRES_USER=iya
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://iya:change_me_strong_password@postgres:5432/iya

# === App ===
OWNER_TELEGRAM_ID=
# Приватный режим: telegram id через запятую, кому разрешён доступ.
# Пусто — бот открыт всем. Владелец имеет доступ всегда.
ALLOWED_TELEGRAM_IDS=
APP_ENV=production
APP_VERSION=0.4.0-manifest-v2
LOG_LEVEL=INFO
TZ=Europe/Moscow
BOT_TIMEZONE=Europe/Moscow
HISTORY_LIMIT=20

# === Человеческая подача ===
HUMANIZE_ENABLED=true
HUMANIZE_MAX_CHUNKS=2
HUMANIZE_MS_PER_CHAR=22
HUMANIZE_MIN_DELAY_SECONDS=0.6
HUMANIZE_MAX_DELAY_SECONDS=4.0

# === Runtime context ===
RUNTIME_CONTEXT_ENABLED=true

# === Memory / proactive / reflection ===
PROACTIVE_ENABLED=true
PROACTIVE_SCAN_INTERVAL_SECONDS=60
PROACTIVE_MIN_DELAY_MINUTES=180
PROACTIVE_MAX_DELAY_MINUTES=720
REFLECTION_ENABLED=true
REFLECTION_INTERVAL_MINUTES=360
REFLECTION_USER_LIMIT=20
REFLECTION_KEEP_RECENT_MESSAGES=200

# === Images ===
TELEGRAM_IMAGE_MAX_BYTES=5000000
VISION_ENABLED=true

# === Tool-calling (инструменты, которые Ия вызывает сама) ===
TOOLS_ENABLED=true
TOOL_MAX_ITERATIONS=4
# Веб-поиск через DuckDuckGo (без ключа).
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_TIMEOUT_SECONDS=15
# Чтение конкретной страницы по URL.
FETCH_URL_ENABLED=true
FETCH_URL_MAX_CHARS=4000
FETCH_URL_TIMEOUT_SECONDS=15
# Осознанное запоминание факта инструментом.
REMEMBER_TOOL_ENABLED=true

# === Авто-память (пассивное извлечение фактов из диалога) ===
AUTO_MEMORY_ENABLED=true
AUTO_MEMORY_MAX_FACTS=5

# === Rate limiting (владелец не ограничен) ===
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MESSAGES=20
RATE_LIMIT_WINDOW_SECONDS=60

# === Голосовые сообщения (Whisper-совместимый endpoint) ===
# Пустые WHISPER_* наследуются от основного LLM-подключения.
VOICE_ENABLED=false
WHISPER_BASE_URL=
WHISPER_API_KEY=
WHISPER_MODEL=whisper-1
TELEGRAM_VOICE_MAX_BYTES=10000000

# === Streaming (живое редактирование ответа в одном сообщении) ===
# Работает только на прямом текстовом пути: без tool-loop и vision.
STREAMING_ENABLED=false
STREAMING_EDIT_INTERVAL_SECONDS=1.5

# === Семантический поиск по памяти (эмбеддинги) ===
# Пустые EMBEDDINGS_* наследуются от основного LLM-подключения.
MEMORY_EMBEDDINGS_ENABLED=false
EMBEDDINGS_BASE_URL=
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small
MEMORY_RETRIEVAL_TOP_K=20

# === Manifest v2 architecture flags ===
MEMORY_FACTS_ENABLED=true
SELF_STATE_ENABLED=true
RELATIONSHIP_STATE_ENABLED=true
MODE_ROUTER_ENABLED=true
PROMPT_BUILDER_V2_ENABLED=true
PROMPT_TOKEN_BUDGET=12000
LLM_LOGGING_ENABLED=true
MOTIVATED_PROACTIVE_ENABLED=false

# Внешний системный промпт.
SYSTEM_PROMPT_PATH=/app/prompts/iya_system.md
