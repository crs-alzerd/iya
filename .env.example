# === Telegram ===
TELEGRAM_BOT_TOKEN=put_telegram_bot_token_here

# === LLM: OpenAI-compatible endpoint ===
# Примеры:
# OpenAI: https://api.openai.com/v1
# LM Studio локально: http://host.docker.internal:1234/v1
# OpenRouter/NanoGPT/etc: смотри URL провайдера
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=put_llm_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60

# === Postgres ===
POSTGRES_DB=iya
POSTGRES_USER=iya
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://iya:change_me_strong_password@postgres:5432/iya

# === App ===
OWNER_TELEGRAM_ID=
APP_ENV=production
APP_VERSION=0.1.1
LOG_LEVEL=INFO
TZ=Europe/Moscow
BOT_TIMEZONE=Europe/Moscow
HISTORY_LIMIT=20
REMINDER_SCAN_INTERVAL_SECONDS=10

# Внешний системный промпт.
# В docker-compose директория ./prompts монтируется в /app/prompts:ro.
# После изменения файла достаточно перезапустить app: docker compose restart app
SYSTEM_PROMPT_PATH=/app/prompts/iya_system.md
