# === Telegram ===
TELEGRAM_BOT_TOKEN=put_telegram_bot_token_here

# === LLM: OpenAI-compatible endpoint ===
# Примеры:
# OpenAI: https://api.openai.com/v1
# LM Studio локально: http://host.docker.internal:1234/v1
# OpenRouter/NanoGPT/etc: смотри URL провайдера
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=put_llm_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60

# Сэмплинг LLM.
# presence/frequency penalty гасят дословные повторы и зацикливание на
# одних и тех же жестах. Если бэкенд (например, конкретная модель в NanoGPT)
# не принимает penalty — оставь пусто, и параметр не будет отправлен.
LLM_TEMPERATURE=0.85
LLM_TOP_P=
LLM_PRESENCE_PENALTY=0.4
LLM_FREQUENCY_PENALTY=0.5
LLM_MAX_TOKENS=

# === Postgres ===
POSTGRES_DB=iya
POSTGRES_USER=iya
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://iya:change_me_strong_password@postgres:5432/iya

# === App ===
OWNER_TELEGRAM_ID=
APP_ENV=production
APP_VERSION=0.2.0
LOG_LEVEL=INFO
TZ=Europe/Moscow
BOT_TIMEZONE=Europe/Moscow
HISTORY_LIMIT=20
REMINDER_SCAN_INTERVAL_SECONDS=10

# === Человеческая подача ===
# Дробление ответа на несколько коротких реплик с имитацией набора текста.
HUMANIZE_ENABLED=true
HUMANIZE_MAX_CHUNKS=3
HUMANIZE_MS_PER_CHAR=22
HUMANIZE_MIN_DELAY_SECONDS=0.6
HUMANIZE_MAX_DELAY_SECONDS=4.0

# Динамический контекст: реальное время суток/день недели + постоянные
# правила анти-повтора и уточнения. Подмешивается в каждый запрос.
RUNTIME_CONTEXT_ENABLED=true

# Внешний системный промпт.
# В docker-compose директория ./prompts монтируется в /app/prompts:ro.
# После изменения файла достаточно перезапустить app: docker compose restart app
SYSTEM_PROMPT_PATH=/app/prompts/iya_system.md
